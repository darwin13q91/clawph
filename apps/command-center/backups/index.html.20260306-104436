    <script>
        const now = new Date();
        document.getElementById('lastUpdated').textContent = now.toLocaleString();
        document.getElementById('footerLastUpdated').textContent = now.toLocaleString();

        // Sub-Agent Monitor
        let ccSubagentData = {
            active: 0,
            recent: [],
            todayTokens: 0,
            status: 'healthy'
        };

        function ccFormatTokens(tokens) {
            if (tokens >= 1000000) return (tokens / 1000000).toFixed(1) + 'M';
            if (tokens >= 1000) return (tokens / 1000).toFixed(0) + 'k';
            return tokens.toString();
        }

        function ccFormatDuration(minutes) {
            if (minutes >= 60) {
                const hours = Math.floor(minutes / 60);
                const mins = minutes % 60;
                return mins > 0 ? `${hours}h ${mins}m` : `${hours}h`;
            }
            return `${minutes}m`;
        }

        function getCCStatusIndicator(status) {
            const indicators = {
                healthy: { emoji: '🟢', class: 'status-healthy', text: 'Healthy' },
                warning: { emoji: '🟡', class: 'status-warning', text: 'Warning' },
                critical: { emoji: '🔴', class: 'status-critical', text: 'Critical' }
            };
            return indicators[status] || indicators.healthy;
        }

        function updateCCSubagentUI() {
            const indicator = getCCStatusIndicator(ccSubagentData.status);

            document.getElementById('cc-subagent-active').textContent = ccSubagentData.active;
            document.getElementById('cc-subagent-tokens').textContent = ccFormatTokens(ccSubagentData.todayTokens);
            document.getElementById('cc-subagent-completed').textContent = ccSubagentData.recent.length;
            document.getElementById('cc-subagent-health').innerHTML = `${indicator.emoji} ${indicator.text}`;
            document.getElementById('cc-subagent-health').style.color =
                ccSubagentData.status === 'healthy' ? 'var(--accent-success)' :
                ccSubagentData.status === 'warning' ? 'var(--accent-warning)' : 'var(--accent-danger)';

            const badge = document.getElementById('cc-subagent-badge');
            badge.textContent = ccSubagentData.active > 0 ? `${ccSubagentData.active} Active` : 'Idle';
            badge.className = 'status-badge ' + (ccSubagentData.active > 0 ? 'status-healthy' : 'status-info');

            const recentList = document.getElementById('cc-subagent-recent');
            if (ccSubagentData.recent.length === 0) {
                recentList.innerHTML = '<div style="font-size: 12px; color: var(--text-muted);">No recent activity</div>';
            } else {
                recentList.innerHTML = ccSubagentData.recent.slice(0, 5).map(agent => `
                    <div style="display: flex; justify-content: space-between; align-items: center; font-size: 12px; padding: 6px; background: var(--bg-secondary); border-radius: 4px;">
                        <span style="display: flex; align-items: center; gap: 6px;">
                            <span style="color: var(--accent-success);">✅</span>
                            ${agent.name}
                        </span>
                        <span style="color: var(--text-muted); font-family: monospace; font-size: 11px;">
                            ${ccFormatDuration(agent.duration)}, ${ccFormatTokens(agent.tokens)}
                        </span>
                    </div>
                `).join('');
            }
        }

        async function fetchCCSubagentData() {
            // In a real implementation, this would call the API
            const demoData = [
                { name: 'deploy-ai-gateway', duration: 14, tokens: 99000 },
                { name: 'update-dashboard', duration: 12, tokens: 64000 },
                { name: 'health-check', duration: 8, tokens: 12000 },
                { name: 'sync-github', duration: 5, tokens: 8500 },
                { name: 'backup-config', duration: 3, tokens: 3200 }
            ];

            ccSubagentData.active = Math.floor(Math.random() * 3);
            ccSubagentData.recent = demoData.slice(0, Math.floor(Math.random() * 5) + 1);
            ccSubagentData.todayTokens = Math.floor(Math.random() * 500000) + 100000;

            const hasLongRunning = ccSubagentData.recent.some(a => a.duration > 30);
            ccSubagentData.status = hasLongRunning ? 'warning' : 'healthy';

            updateCCSubagentUI();
        }

        // Email Monitor
        async function testEmailConnection() {
            const badge = document.getElementById('email-status-badge');
            badge.textContent = '🟡 Testing...';
            badge.className = 'status-badge status-warning';

            await new Promise(r => setTimeout(r, 1500));

            badge.textContent = '🟢 Connected';
            badge.className = 'status-badge status-healthy';

            alert('✅ Email connection test successful!\n\nAll 3 accounts connected:\n• hello@amajungle.com\n• ops@amajungle.com\n• support@amajungle.com');
        }

        // Inbox Monitor - Real IMAP Data
        async function refreshInbox() {
            try {
                // Add timeout
                const controller = new AbortController();
                const timeoutId = setTimeout(() => controller.abort(), 8000);
                
                // Fetch data from dashboard API
                const response = await fetch('http://localhost:8789/api/inbox?account=all', { 
                    signal: controller.signal 
                });
                clearTimeout(timeoutId);
                
                const data = await response.json();

                // Update account unread counts
                const helloUnread = data.accounts?.hello?.unread || 0;
                const opsUnread = data.accounts?.ops?.unread || 0;
                const supportUnread = data.accounts?.support?.unread || 0;
                const total = data.total_unread || 0;
                
                document.getElementById('inbox-hello').textContent = helloUnread > 0 ? `🔴 ${helloUnread} unread` : '✅ 0 unread';
                document.getElementById('inbox-hello').style.color = helloUnread > 0 ? 'var(--accent-warning)' : 'var(--accent-success)';
                
                document.getElementById('inbox-ops').textContent = opsUnread > 0 ? `🔴 ${opsUnread} unread` : '✅ 0 unread';
                document.getElementById('inbox-ops').style.color = opsUnread > 0 ? 'var(--accent-warning)' : 'var(--accent-success)';
                
                document.getElementById('inbox-support').textContent = supportUnread > 0 ? `🔴 ${supportUnread} unread` : '✅ 0 unread';
                document.getElementById('inbox-support').style.color = supportUnread > 0 ? 'var(--accent-warning)' : 'var(--accent-success)';
                
                document.getElementById('inbox-total').textContent = total > 0 ? `${total} unread` : '0 unread';
                
                // Update recent list from all accounts
                const recentList = document.getElementById('email-recent-list');
                let allRecent = [];
                
                Object.entries(data.accounts || {}).forEach(([account, accData]) => {
                    if (accData.recent) {
                        accData.recent.slice(0, 2).forEach(email => {
                            allRecent.push({ ...email, account });
                        });
                    }
                });
                
                // Show last 5 emails
                allRecent = allRecent.slice(0, 5);
                
                if (allRecent.length === 0) {
                    recentList.innerHTML = '<div style="font-size: 12px; color: var(--text-muted);">No recent emails</div>';
                } else {
                    recentList.innerHTML = allRecent.map(email => `
                        <div style="display: flex; justify-content: space-between; align-items: center; font-size: 12px; padding: 8px; background: var(--bg-secondary); border-radius: 4px;">
                            <span style="display: flex; align-items: center; gap: 8px; flex: 1;">
                                <span style="color: ${email.unread ? 'var(--accent-warning)' : 'var(--accent-info)'};">${email.unread ? '🔴' : '📧'}</span>
                                <span style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">${email.subject}</span>
                            </span>
                            <span style="color: var(--text-muted); font-size: 10px; background: var(--bg-elevated); padding: 2px 6px; border-radius: 4px;">${email.account}</span>
                        </div>
                    `).join('');
                }
                
            } catch (err) {
                console.error('Failed to load inbox:', err);
                
                // Set fallback values
                document.getElementById('inbox-hello').textContent = '⚠️ --';
                document.getElementById('inbox-ops').textContent = '⚠️ --';
                document.getElementById('inbox-support').textContent = '⚠️ --';
                document.getElementById('inbox-total').textContent = '--';
                document.getElementById('email-recent-list').innerHTML = 
                    '<div style="font-size: 12px; color: var(--text-muted);">⚠️ Inbox temporarily unavailable</div>';
            }
        }

        // Budget Burn Rate for Command Center
        function updateCCBudget() {
            const monthlyIncome = 1800;
            const daysInMonth = new Date(new Date().getFullYear(), new Date().getMonth() + 1, 0).getDate();
            const currentDay = new Date().getDate();
            
            const expectedSpend = (monthlyIncome / daysInMonth) * currentDay;
            const percentUsed = Math.round((expectedSpend / monthlyIncome) * 100);
            const remaining = monthlyIncome - expectedSpend;
            
            document.getElementById('cc-budget-spent').textContent = `$${Math.round(expectedSpend)}`;
            document.getElementById('cc-budget-remaining').textContent = `$${Math.round(remaining)}`;
            document.getElementById('cc-budget-bar').style.width = `${percentUsed}%`;
            document.getElementById('cc-budget-pct').textContent = `${percentUsed}%`;
            
            // Update status badge
            const statusBadge = document.getElementById('cc-budget-status');
            if (percentUsed < 50) {
                statusBadge.textContent = 'On Track';
                statusBadge.className = 'status-badge status-healthy';
                document.getElementById('cc-budget-bar').style.background = 'var(--accent-success)';
            } else if (percentUsed < 80) {
                statusBadge.textContent = 'Caution';
                statusBadge.className = 'status-badge status-warning';
                document.getElementById('cc-budget-bar').style.background = 'var(--accent-warning)';
            } else {
                statusBadge.textContent = 'Alert!';
                statusBadge.className = 'status-badge status-danger';
                document.getElementById('cc-budget-bar').style.background = 'var(--accent-danger)';
            }
        }

        // Email Campaigns for Command Center
        function updateCCCampaigns() {
            // In real implementation, fetch from API or log files
            // For now, show placeholder data
            document.getElementById('cc-campaign-sent').textContent = '0';
            document.getElementById('cc-campaign-replies').textContent = '0';
            document.getElementById('cc-campaign-meetings').textContent = '0';
        }

        // River - Amazon Specialist spawn function
        function spawnRiver(mode) {
            const status = document.getElementById('river-status');
            const last = document.getElementById('river-last');
            
            status.textContent = '🟡 Spawning...';
            status.className = 'status-badge status-warning';
            
            // Simulate spawn delay
            setTimeout(() => {
                status.textContent = '🟢 Active';
                status.className = 'status-badge status-success';
                last.textContent = new Date().toLocaleTimeString();
                
                alert(`🌊 River spawned in mode: ${mode}\n\nRiver is now analyzing your Amazon strategy. Check Telegram for the full report.`);
            }, 1500);
        }

        // Piper - Email Manager spawn function
        function spawnPiper(task) {
            const status = document.getElementById('piper-status');
            const last = document.getElementById('piper-last');
            
            status.textContent = '🟡 Spawning...';
            status.className = 'status-badge status-warning';
            
            setTimeout(() => {
                status.textContent = '🟢 Active';
                status.className = 'status-badge status-success';
                last.textContent = new Date().toLocaleTimeString();
                
                alert(`📧 Piper spawned for: ${task}\n\nPiper is now managing your email pipeline. Check Telegram for updates.`);
            }, 1500);
        }

        // Atlas - Fullstack Developer spawn function
        function spawnAtlas(mode) {
            const status = document.getElementById('atlas-status');
            const last = document.getElementById('atlas-last');
            
            status.textContent = '🟡 Spawning...';
            status.className = 'status-badge status-warning';
            
            setTimeout(() => {
                status.textContent = '🟢 Active';
                status.className = 'status-badge status-success';
                last.textContent = new Date().toLocaleTimeString();
                
                const modeNames = {
                    'website': '🌐 Website Development',
                    'platform': '⚙️ Platform Maintenance',
                    'security': '🔒 Security Audit'
                };
                const modeName = modeNames[mode] || mode;
                
                alert(`🏛️ Atlas spawned for: ${modeName}\n\nAtlas is now working on your infrastructure. Check Telegram for updates.`);
            }, 1500);
        }

        // Initial loads
        refreshInbox();
        setInterval(refreshInbox, 60000);

        updateCCBudget();
        setInterval(updateCCBudget, 3600000); // Update hourly

        updateCCCampaigns();
        setInterval(updateCCCampaigns, 60000);

        fetchCCSubagentData();
        setInterval(fetchCCSubagentData, 15000);
    </script>
