<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="refresh" content="300">
    <title>Command Center | Unified Dashboard</title>
    <style>
        :root {
            --bg-primary: #0a0a0a;
            --bg-secondary: #111111;
            --bg-elevated: #1a1a1a;
            --text-primary: #fafafa;
            --text-secondary: #a3a3a3;
            --text-muted: #737373;
            --border-color: #262626;
            --accent-success: #22c55e;
            --accent-warning: #f59e0b;
            --accent-danger: #ef4444;
            --accent-info: #3b82f6;
            --accent-primary: #6366f1;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            line-height: 1.5;
        }

        .container { max-width: 1400px; margin: 0 auto; padding: 24px; }

        header {
            display: flex; justify-content: space-between; align-items: center;
            padding-bottom: 24px; border-bottom: 1px solid var(--border-color); margin-bottom: 24px;
        }

        h1 { font-size: 28px; font-weight: 700; }
        .subtitle { color: var(--text-muted); font-size: 14px; }

        .status-badge {
            padding: 8px 16px; border-radius: 20px; font-size: 14px; font-weight: 600;
        }
        .status-healthy { background: rgba(34, 197, 94, 0.15); color: var(--accent-success); }
        .status-warning { background: rgba(245, 158, 11, 0.15); color: var(--accent-warning); }
        .status-critical { background: rgba(239, 68, 68, 0.15); color: var(--accent-danger); }
        .status-info { background: rgba(59, 130, 246, 0.15); color: var(--accent-info); }

        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 24px; }

        .card { background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 12px; padding: 20px; }

        .card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
        .card-title { font-size: 16px; font-weight: 600; display: flex; align-items: center; gap: 8px; }
        .card-icon { font-size: 20px; }

        .metric { display: flex; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid var(--border-color); }
        .metric:last-child { border-bottom: none; }
        .metric-label { color: var(--text-secondary); font-size: 14px; }
        .metric-value { font-weight: 600; font-family: 'SF Mono', monospace; }

        .feature-list { list-style: none; padding: 0; }
        .feature-list li { padding: 6px 0; font-size: 13px; color: var(--text-secondary); border-bottom: 1px solid var(--border-color); }
        .feature-list li:last-child { border-bottom: none; }
        .feature-list li::before { content: '✓ '; color: var(--accent-success); font-weight: bold; }

        .pricing-row { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 12px; }
        .pricing-badge { background: var(--bg-elevated); padding: 4px 10px; border-radius: 12px; font-size: 12px; font-weight: 500; }

        .strategy-tag { display: inline-block; background: var(--bg-elevated); padding: 4px 10px; border-radius: 12px; font-size: 12px; margin-right: 6px; margin-bottom: 6px; }

        .schedule-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
        .schedule-item { background: var(--bg-elevated); padding: 10px; border-radius: 6px; text-align: center; }
        .schedule-time { font-size: 16px; font-weight: 700; color: var(--accent-primary); }
        .schedule-label { font-size: 11px; color: var(--text-muted); margin-top: 2px; }

        .external-link { font-size: 12px; color: var(--accent-info); text-decoration: none; }
        .external-link:hover { text-decoration: underline; }

        .nav-links { display: flex; gap: 16px; margin-top: 24px; flex-wrap: wrap; }
        .nav-link { color: var(--accent-info); text-decoration: none; font-size: 14px; }
        .nav-link:hover { text-decoration: underline; }

        .footer { margin-top: 40px; padding-top: 20px; border-top: 1px solid var(--border-color); text-align: center; color: var(--text-muted); font-size: 13px; }

        .refresh-btn { background: var(--bg-elevated); border: 1px solid var(--border-color); color: var(--text-secondary); padding: 8px 16px; border-radius: 6px; cursor: pointer; font-size: 13px; }
        .refresh-btn:hover { background: var(--border-color); color: var(--text-primary); }

        .quick-actions { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px; }
        .quick-btn { background: var(--bg-elevated); border: 1px solid var(--border-color); color: var(--text-secondary); padding: 8px 14px; border-radius: 6px; cursor: pointer; font-size: 12px; text-decoration: none; display: inline-block; }
        .quick-btn:hover { background: var(--border-color); color: var(--text-primary); }
        .quick-btn.primary { background: var(--accent-primary); border-color: var(--accent-primary); color: white; }
        .quick-btn.primary:hover { background: var(--accent-info); }

        @media (max-width: 768px) {
            .grid { grid-template-columns: 1fr; }
            .schedule-grid { grid-template-columns: 1fr; }
            header { flex-direction: column; gap: 12px; align-items: flex-start; }
        }
    </style>
</head>
