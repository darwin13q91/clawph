    <script>
        function scrollToSection(id) {
            const el = document.getElementById(id);
            if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        // Email functions
        async function testEmailConnection() {
            const badge = document.getElementById('email-panel-badge');
            const stat = document.getElementById('email-stat-status');
            const lastActivity = document.getElementById('email-last-activity');
            
            badge.textContent = '🟡 Testing...';
            badge.className = 'badge badge-warning';
            
            // Simulate connection test
            await new Promise(r => setTimeout(r, 1500));
            
            badge.textContent = '🟢 Connected';
            badge.className = 'badge badge-success';
            stat.textContent = '🟢 Ready';
            lastActivity.textContent = new Date().toLocaleTimeString();
        }

        async function sendTestEmail() {
            const to = document.getElementById('test-email-to').value;
            const subject = document.getElementById('test-email-subject').value;
            const statusDiv = document.getElementById('email-send-status');
            
            if (!to || !subject) {
                statusDiv.innerHTML = '<span style="color: var(--accent-danger)">❌ Please fill in both fields</span>';
                return;
            }
            
            statusDiv.innerHTML = '<span style="color: var(--accent-info)">🟡 Sending...</span>';
            
            // Simulate sending
            await new Promise(r => setTimeout(r, 2000));
            
            statusDiv.innerHTML = '<span style="color: var(--accent-success)">✅ Test email sent to ' + to + '</span>';
            document.getElementById('email-last-activity').textContent = new Date().toLocaleTimeString();
            
            // Clear after 5 seconds
            setTimeout(() => {
                statusDiv.innerHTML = '';
            }, 5000);
        }

        // Update timestamp
        document.getElementById('lastUpdated').textContent = new Date().toLocaleString();

        // Sub-Agent Monitor
        let subagentData = {
            active: 0,
            recent: [],
            todayTokens: 0,
            status: 'healthy'
        };

        function formatTokens(tokens) {
            if (tokens >= 1000000) return (tokens / 1000000).toFixed(1) + 'M';
            if (tokens >= 1000) return (tokens / 1000).toFixed(0) + 'k';
            return tokens.toString();
        }

        function formatDuration(minutes) {
            if (minutes >= 60) {
                const hours = Math.floor(minutes / 60);
                const mins = minutes % 60;
                return mins > 0 ? `${hours}h ${mins}m` : `${hours}h`;
            }
            return `${minutes}m`;
        }

        function getStatusIndicator(status) {
            const indicators = {
                healthy: { emoji: '🟢', color: 'var(--accent-success)', text: 'All systems operational' },
                warning: { emoji: '🟡', color: 'var(--accent-warning)', text: 'Some agents running long' },
                critical: { emoji: '🔴', color: 'var(--accent-danger)', text: 'Agents may be stuck' }
            };
            return indicators[status] || indicators.healthy;
        }

        function updateSubagentUI() {
            const indicator = getStatusIndicator(subagentData.status);
            
            // Update stats grid
            document.getElementById('subagent-count').textContent = subagentData.active;
            document.getElementById('subagent-status-text').textContent = subagentData.active > 0 ? `${subagentData.active} running` : 'No active';
            document.getElementById('subagent-status-text').className = subagentData.active > 0 ? 'stat-change positive' : 'stat-change';
            
            // Update panel
            document.getElementById('subagent-active').textContent = subagentData.active;
            document.getElementById('subagent-tokens').textContent = formatTokens(subagentData.todayTokens);
            document.getElementById('subagent-completed').textContent = subagentData.recent.length;
            
            // Health status
            document.getElementById('subagent-health').textContent = indicator.emoji;
            document.getElementById('subagent-health').style.color = indicator.color;
            document.getElementById('subagent-health-detail').textContent = indicator.text;
            document.getElementById('subagent-health-detail').style.color = indicator.color;
            
            // Badge
            const badge = document.getElementById('subagent-badge');
            badge.textContent = subagentData.active > 0 ? `${subagentData.active} Active` : 'Idle';
            badge.className = 'badge ' + (subagentData.active > 0 ? 'badge-success' : 'badge-info');
            
            // Recent list
            const recentList = document.getElementById('subagent-recent-list');
            if (subagentData.recent.length === 0) {
                recentList.innerHTML = `
                    <div style="padding: 12px; background: var(--bg-secondary); border-radius: var(--radius-sm); display: flex; align-items: center; gap: 12px;">
                        <span style="color: var(--text-muted);">No recent sub-agent activity</span>
                    </div>
                `;
            } else {
                recentList.innerHTML = subagentData.recent.slice(0, 5).map(agent => `
                    <div style="padding: 12px; background: var(--bg-secondary); border-radius: var(--radius-sm); display: flex; align-items: center; gap: 12px;">
                        <span style="color: var(--accent-success);">✅</span>
                        <span style="font-weight: 500; flex: 1;">${agent.name}</span>
                        <span style="color: var(--text-muted); font-size: 12px; font-family: 'JetBrains Mono', monospace;">
                            ${formatDuration(agent.duration)}, ${formatTokens(agent.tokens)}
                        </span>
                    </div>
                `).join('');
            }
            
            // Footer
            document.getElementById('subagent-footer-status').textContent = 
                `Status: ${indicator.text} • Last updated: ${new Date().toLocaleTimeString()}`;
        }

        async function fetchSubagentData() {
            try {
