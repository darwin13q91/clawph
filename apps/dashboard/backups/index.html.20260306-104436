        // Budget display - fetch real CFO data
        async function updateBudgetDisplay() {
            try {
                const response = await fetch('/api/cfo', {
                    signal: AbortSignal.timeout(5000)
                });
                
                if (!response.ok) {
                    throw new Error('CFO API returned ' + response.status);
                }
                
                const data = await response.json();
                
                // Calculate budget values
                const monthlyIncome = data.monthly_income || 0;
                const monthlyExpenses = data.monthly_expenses || 0;
                const currentBalance = data.current_balance || 0;
                const surplus = monthlyIncome - monthlyExpenses;
                const daysRemaining = data.daysRemaining || 30;
                
                // Update budget panel elements
                const budgetSpent = document.getElementById('budget-spent');
                const budgetSpentPct = document.getElementById('budget-spent-pct');
                const budgetRemaining = document.getElementById('budget-remaining');
                const budgetDays = document.getElementById('budget-days');
                const budgetProjected = document.getElementById('budget-projected');
                const budgetProjectedStatus = document.getElementById('budget-projected-status');
                const budgetStatus = document.getElementById('budget-status');
                const budgetBar = document.getElementById('budget-bar');
                const budgetBarText = document.getElementById('budget-bar-text');
                
                if (budgetSpent) budgetSpent.textContent = `$${monthlyExpenses.toLocaleString()}`;
                if (budgetRemaining) budgetRemaining.textContent = `$${currentBalance.toLocaleString()}`;
                if (budgetDays) budgetDays.textContent = daysRemaining;
                
                // Calculate spent percentage
                const spentPct = monthlyIncome > 0 ? Math.round((monthlyExpenses / monthlyIncome) * 100) : 0;
                if (budgetSpentPct) {
                    budgetSpentPct.textContent = `${spentPct}% of budget`;
                    budgetSpentPct.className = spentPct > 80 ? 'stat-change negative' : 'stat-change';
                }
                
                // Projected end of month
                const dailyBurn = monthlyExpenses / 30;
                const projectedSpend = monthlyExpenses + (dailyBurn * daysRemaining);
                if (budgetProjected) budgetProjected.textContent = `$${Math.round(projectedSpend).toLocaleString()}`;
                if (budgetProjectedStatus) {
                    const projectedStatus = projectedSpend <= monthlyIncome ? 'Under Budget' : 'Over Budget';
                    budgetProjectedStatus.textContent = projectedStatus;
                    budgetProjectedStatus.className = projectedSpend <= monthlyIncome ? 'stat-change positive' : 'stat-change negative';
                }
                
                // Status badge
                if (budgetStatus) {
                    if (spentPct > 90) {
                        budgetStatus.textContent = 'Critical';
                        budgetStatus.className = 'badge badge-error';
                    } else if (spentPct > 75) {
                        budgetStatus.textContent = 'Warning';
                        budgetStatus.className = 'badge badge-warning';
                    } else {
                        budgetStatus.textContent = 'On Track';
                        budgetStatus.className = 'badge badge-success';
                    }
                }
                
                // Progress bar
                if (budgetBar) {
                    budgetBar.style.width = `${Math.min(spentPct, 100)}%`;
                    budgetBar.style.background = spentPct > 90 ? 'var(--accent-error)' : 
                                                  spentPct > 75 ? 'var(--accent-warning)' : 
                                                  'var(--accent-success)';
                }
                if (budgetBarText) budgetBarText.textContent = `${spentPct}% spent`;
                
                // Update revenue section in CFO panel
                const revenueCurrent = document.getElementById('revenue-current');
                const revenueGap = document.getElementById('revenue-gap');
                
                if (revenueCurrent) revenueCurrent.textContent = `$${monthlyIncome.toLocaleString()}`;
                if (revenueGap) {
                    const gap = Math.max(0, monthlyExpenses - monthlyIncome);
                    revenueGap.textContent = gap > 0 ? `$${gap.toLocaleString()}` : '$0';
                    revenueGap.style.color = gap > 0 ? 'var(--accent-error)' : 'var(--accent-success)';
                }
                
                console.log('CFO data updated:', data);
            } catch (err) {
                console.error('Failed to fetch CFO data:', err);
                
                // Set error state
                const budgetStatus = document.getElementById('budget-status');
                const budgetSpent = document.getElementById('budget-spent');
                
                if (budgetStatus) {
                    budgetStatus.textContent = 'Error';
                    budgetStatus.className = 'badge badge-error';
                }
                if (budgetSpent) budgetSpent.textContent = '—';
            }
        }

