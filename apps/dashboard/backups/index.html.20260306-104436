                });
                
                if (!response.ok) {
                    throw new Error('Subagents API returned ' + response.status);
                }
                
                const data = await response.json();
                
                // Update the UI with real data
                subagentData.recent = data.recentRuns || [];
                subagentData.active = data.active || 0;
                subagentData.todayTokens = data.todayTokens || 0;
                subagentData.status = data.status || 'unknown';
                updateSubagentUI();
                
                console.log('Subagent data updated:', data);
            } catch (err) {
                console.error('Failed to fetch subagent data:', err);
                // Fallback to demo data on error
                const demoData = [
                    { name: 'deploy-ai-gateway', duration: 14, tokens: 99000 },
                    { name: 'update-dashboard', duration: 12, tokens: 64000 },
                    { name: 'health-check', duration: 8, tokens: 12000 },
                    { name: 'sync-github', duration: 5, tokens: 8500 },
                    { name: 'backup-config', duration: 3, tokens: 3200 }
                ];
                subagentData.recent = demoData;
                subagentData.active = 0;
                subagentData.todayTokens = demoData.reduce((sum, d) => sum + d.tokens, 0);
                subagentData.status = 'error';
                updateSubagentUI();
            }
        }
            
        // Multi-Account Inbox Monitor - Real IMAP Data
        async function refreshAllInboxes() {
            try {
                // Create AbortController for timeout support
                const controller = new AbortController();
                const timeoutId = setTimeout(() => controller.abort(), 15000);

                const response = await fetch('/api/inbox?account=all', { signal: controller.signal });
                clearTimeout(timeoutId);

                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }

                const data = await response.json();

                // Validate data structure
                if (!data || typeof data !== 'object') {
                    throw new Error('Invalid data structure received');
                }

                // Update stat card
                const statUnread = document.getElementById('email-stat-unread');
                const total = data.total_unread || 0;
                if (statUnread) {
                    statUnread.textContent = total > 0 ? `🔴 ${total}` : '✅ 0';
                    statUnread.style.color = total > 0 ? 'var(--accent-warning)' : 'var(--accent-success)';
                }

                // Update panel counts
                ['hello', 'ops', 'support'].forEach(acc => {
                    const accData = data.accounts?.[acc] || { unread: 0 };
                    const unread = accData.unread || 0;
                    const el = document.getElementById(`inbox-${acc}-unread`);
                    if (el) {
                        el.textContent = unread;
                        el.style.color = unread > 0 ? 'var(--accent-warning)' : 'var(--accent-success)';
                    }
                });

                // Update recent emails list
                const recentList = document.getElementById('inbox-recent-list');
                if (!recentList) return;

                let allRecent = [];

                if (data.accounts) {
                    Object.entries(data.accounts).forEach(([account, accData]) => {
                        if (accData && accData.recent && Array.isArray(accData.recent)) {
                            accData.recent.forEach(email => {
                                if (email && typeof email === 'object') {
                                    allRecent.push({ ...email, account });
                                }
                            });
                        }
                    });
                }

                allRecent = allRecent.slice(0, 5);

                if (allRecent.length === 0) {
                    recentList.innerHTML = '<div style="font-size: 12px; color: var(--text-muted);">No recent emails</div>';
                } else {
                    recentList.innerHTML = allRecent.map(email => {
                        const isUnread = email.unread === true;
                        const subject = email.subject || 'No Subject';
                        const from = email.from || 'Unknown';
                        const account = email.account || 'unknown';
                        return `
                        <div style="display: flex; justify-content: space-between; align-items: center; padding: 10px; background: var(--bg-secondary); border-radius: var(--radius-sm);">
                            <div style="display: flex; align-items: center; gap: 10px; flex: 1; min-width: 0;">
                                <span style="color: ${isUnread ? 'var(--accent-warning)' : 'var(--text-muted)'}">${isUnread ? '🔴' : '📧'}</span>
                                <span style="font-weight: ${isUnread ? '600' : '400'}; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">${subject}</span>
                            </div>
                            <div style="display: flex; align-items: center; gap: 12px; flex-shrink: 0;">
                                <span style="font-size: 10px; color: var(--accent-primary); background: var(--bg-elevated); padding: 2px 6px; border-radius: 4px;">${account}</span>
                                <span style="font-size: 11px; color: var(--text-muted); font-family: monospace;">${from}</span>
                            </div>
                        </div>
                    `}).join('');
                }

                // Update badge
                const badge = document.getElementById('email-panel-badge');
                if (badge) {
                    // Check if any account has errors
                    let hasErrors = false;
                    if (data.accounts) {
                        Object.values(data.accounts).forEach(acc => {
                            if (acc && acc.error) hasErrors = true;
                        });
                    }

                    if (hasErrors) {
                        badge.textContent = '🟡 Partial';
                        badge.className = 'badge badge-warning';
                    } else if (total > 0) {
                        badge.textContent = `🔴 ${total} unread`;
                        badge.className = 'badge badge-warning';
                    } else {
                        badge.textContent = '🟢 Connected';
                        badge.className = 'badge badge-success';
                    }
                }

            } catch (err) {
                console.error('Failed to refresh inboxes:', err);

                // Set error state on UI elements
                const statUnread = document.getElementById('email-stat-unread');
                if (statUnread) {
                    statUnread.textContent = '⚠️ Error';
                    statUnread.style.color = 'var(--accent-danger)';
                }

                ['hello', 'ops', 'support'].forEach(acc => {
                    const el = document.getElementById(`inbox-${acc}-unread`);
                    if (el) el.textContent = '--';
                });

                const recentList = document.getElementById('inbox-recent-list');
                if (recentList) {
                    recentList.innerHTML = '<div style="font-size: 12px; color: var(--text-muted);">⚠️ Inbox temporarily unavailable</div>';
                }

                const badge = document.getElementById('email-panel-badge');
                if (badge) {
                    badge.textContent = '🟡 Error';
                    badge.className = 'badge badge-warning';
                }
            }
        }

