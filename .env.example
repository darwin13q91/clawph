# OpenClaw Environment Variables
# Copy to ~/.openclaw/.env and fill in your values

# ============================================
# TELEGRAM BOT TOKENS
# ============================================
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN_ADMIN=8614261430:AAGWQ1TcNWXB4zrGu_-KrdlAPT9k_Vaova0
TELEGRAM_BOT_TOKEN_ALERTS=8606070459:AAEsiAmLNv0gxyICsUib_EYjIOkylToWjfU
TELEGRAM_BOT_TOKEN_BOBS=YOUR_BOBS_BOT_TOKEN_HERE
TELEGRAM_BOT_TOKEN_ALLYSA=YOUR_ALLYSA_BOT_TOKEN_HERE

# ============================================
# API KEYS
# ============================================

# Kimi (Your Allegretto Plan)
# Get from: https://platform.moonshot.cn/
KIMI_API_KEY=sk-kimi-YOUR_KEY_HERE

# OpenAI (For Client Bots - Recommended)
# Get from: https://platform.openai.com/
OPENAI_API_KEY=sk-openai-YOUR_KEY_HERE

# ============================================
# PAYMENTS (PH-localized checkout)
# ============================================
# Provider switch: manual (dev/default) | xendit | paymongo
# Set to xendit or paymongo and fill in the respective keys below
# to enable live webhook processing with that provider.
PAYMENT_PROVIDER=manual
PAYMENT_NOTIFICATION_EMAIL=hello@amajungle.com
PAYMENT_FROM_EMAIL=hello@amajungle.com
PHP_USD_EXCHANGE_RATE=57.5
# Resend for checkout email notifications
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx

# ── Xendit (https://dashboard.xendit.co) ────────────────────────────────
# Set PAYMENT_PROVIDER=xendit to activate
# XENDIT_SECRET_KEY: Dashboard → Developers → API Keys
# XENDIT_CALLBACK_TOKEN: Dashboard → Developers → Callbacks → Webhook callback token
# XENDIT_WEBHOOK_URL: Set this in Xendit dashboard to https://your-domain.com/api/payments/webhook/xendit
XENDIT_SECRET_KEY=YOUR_XENDIT_SECRET_KEY
XENDIT_CALLBACK_TOKEN=YOUR_XENDIT_CALLBACK_TOKEN

# ── PayMongo (https://dashboard.paymongo.com) ────────────────────────────
# Set PAYMENT_PROVIDER=paymongo to activate
# PAYMONGO_SECRET_KEY: Dashboard → Developers → API Keys → sk_live_xxx or sk_test_xxx
# PAYMONGO_SIGNING_KEY: Dashboard → Developers → Webhooks → Signing key
# PAYMONGO_WEBHOOK_URL: Set this in PayMongo dashboard to https://your-domain.com/api/payments/webhook/paymongo
PAYMONGO_SECRET_KEY=YOUR_PAYMONGO_SECRET_KEY
PAYMONGO_SIGNING_KEY=YOUR_PAYMONGO_SIGNING_KEY

# ── Ops access control ──────────────────────────────────────────────────
# Comma-separated list of Google-email addresses allowed to access /admin/ops
# and the operations API. Must match the authenticated Google session email.
OPS_EMAIL=hello@amajungle.com

# ============================================
# GOOGLE OAUTH (ClawPH checkout authentication)
# ============================================
# Google Cloud Console: https://console.cloud.google.com/
# Create OAuth 2.0 Client ID (Web application), add Authorized JavaScript origins:
#   - http://localhost:5173  (local dev)
#   - https://clawph.com     (production)
#   - https://clawph.vercel.app  (preview deployments)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# Session signing secret — generate with: openssl rand -hex 32
SESSION_SECRET=YOUR_32_BYTE_HEX_SECRET_HERE

# ============================================
# SECURITY
# ============================================
# Generate a random token: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=your-random-token-here

# ============================================
# OPTIONAL: VPS Connection (if using VPS)
# ============================================
VPS_IP=157.245.152.57
VPS_USER=root
VPS_PASSWORD=your-vps-password

# ============================================
# SUPABASE (ClawPH database — source of truth)
# ============================================
# Get from: https://supabase.com/dashboard → your project → Settings → API
#
# SUPABASE_URL: e.g. https://xyzabc.supabase.co
# SUPABASE_SERVICE_KEY: service_role key (NOT the anon key — keep server-side only)
#
# Run the schema first:
#   supabase/schema.sql — paste into Supabase SQL Editor (Dashboard → SQL Editor → New query)
#
# Without these vars, checkout still works via email/console notification (graceful degradation).
# With these vars, every checkout is persisted to Supabase as the source of truth.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
