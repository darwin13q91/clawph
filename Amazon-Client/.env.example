# Amazon-Client Service Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# SECURITY - CRITICAL
# ============================================================================
# Generate a strong master encryption key (32+ characters)
MASTER_ENCRYPTION_KEY=your-super-secure-encryption-key-change-this

# ============================================================================
# AMAZON SP-API CREDENTIALS
# ============================================================================
# Get these from Amazon Seller Central Developer Console
SP_API_CLIENT_ID=amzn1.application-oa2-client.xxxxxxxx
SP_API_CLIENT_SECRET=xxxxxxxxxxxxxxxx

# AWS Credentials for SP-API (IAM user with appropriate permissions)
AWS_ACCESS_KEY_ID=AKIAxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxx

# ============================================================================
# DOMAIN CONFIGURATION
# ============================================================================
AC_BASE_DOMAIN=amazon-client.yourdomain.com

# ============================================================================
# DATABASE PASSWORDS (Generated by onboard-client.sh)
# DO NOT EDIT MANUALLY - These are created automatically
# ============================================================================
SHARED_DB_PASSWORD=generate-a-secure-password
# CLIENT_xxx_DB_PASSWORD entries added automatically per client

# ============================================================================
# OPTIONAL - ADVANCED CONFIGURATION
# ============================================================================
# Rate limiting (requests per second)
MAX_REQUESTS_PER_SECOND=20

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Redis configuration
REDIS_URL=redis://redis:6379

# Node environment
NODE_ENV=production
