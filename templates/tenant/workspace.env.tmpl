# =============================================================================
# ClawPH Tenant Workspace Environment Configuration
# =============================================================================
# Customer: {{CUSTOMER_EMAIL}}
# Workspace: {{SLUG}}
# Plan: {{PLAN_ID}}
# Generated: {{TIMESTAMP}}
# Bootstrap dir: {{TENANT_RUNTIME_DIR}}
# =============================================================================
#
# IMPORTANT: Replace all {{PLACEHOLDER}} values before deploying.
# This file should be treated as a secret — do not commit to version control.
#
# =============================================================================

# ── Workspace Identity ──────────────────────────────────────────────────────

CLAWPH_WORKSPACE_ID={{WORKSPACE_ID}}
CLAWPH_SLUG={{SLUG}}
CLAWPH_PLAN_ID={{PLAN_ID}}
CLAWPH_CUSTOMER_EMAIL={{CUSTOMER_EMAIL}}
CLAWPH_JOB_ID={{JOB_ID}}

# ── OpenClaw Gateway ───────────────────────────────────────────────────────

# The WebSocket URL of the OpenClaw gateway this tenant connects to.
# For local development: ws://127.0.0.1:18789
OPENCLAW_GATEWAY_URL={{OPENCLAW_GATEWAY_URL}}

# The authentication token for this tenant's gateway access.
# Generate via: openclaw gateway token create --tenant {{SLUG}}
OPENCLAW_GATEWAY_TOKEN={{OPENCLAW_GATEWAY_TOKEN}}

# ── Agent Session ──────────────────────────────────────────────────────────

# The OpenClaw agent session ID for this tenant's dedicated agent.
# This is created when you provision the agent in the OpenClaw control plane.
AGENT_SESSION_ID={{AGENT_SESSION_ID}}

# ── LLM Configuration ───────────────────────────────────────────────────────

# Your AI model provider (e.g., openai, anthropic, google, openrouter)
LLM_PROVIDER={{LLM_PROVIDER}}

# The specific model to use (e.g., gpt-4o-mini, claude-3-haiku-20240307)
LLM_MODEL={{LLM_MODEL}}

# API key for your LLM provider
LLM_API_KEY={{LLM_API_KEY}}

# ── Database (if using a per-tenant database) ─────────────────────────────

# Connection string for the tenant's dedicated database
DATABASE_URL={{DATABASE_URL}}

# Token for database authentication
DATABASE_TOKEN={{DATABASE_TOKEN}}

# ── Telegram Channel ───────────────────────────────────────────────────────

# Telegram channel ID for this customer (create a new channel per customer)
# Get this by adding @userinfobot to the channel
TELEGRAM_CHANNEL_ID={{TELEGRAM_CHANNEL_ID}}

# Bot token from @BotFather for the customer's Telegram bot
TELEGRAM_BOT_TOKEN={{TELEGRAM_BOT_TOKEN}}

# ── Notification Settings ──────────────────────────────────────────────────

# Whether to send onboarding notifications to the customer
SEND_WELCOME_MESSAGE=true

# Email for the tenant owner
TENANT_OWNER_EMAIL={{CUSTOMER_EMAIL}}

# ── Feature Flags ─────────────────────────────────────────────────────────

# Enable/disable features per plan
FEATURE_PHILGEPS_MONITOR={{PHILGEPS_MONITOR_ENABLED}}
FEATURE_PHILSCOUT={{PHILSCOUT_ENABLED}}
FEATURE_BIR_MONITOR={{BIR_MONITOR_ENABLED}}
