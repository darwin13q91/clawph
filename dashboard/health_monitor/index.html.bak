<!DOCTYPE html>
<html>
<head>
    <title>AmaJungle Health Monitor - Live Dashboard</title>
    <meta http-equiv="refresh" content="30">
    <style>
        * { box-sizing: border-box; }
        :root {
            --jungle-green: #0B3A2C;
            --jungle-green-light: #0D4534;
            --neon-lime: #9FBF00;
            --neon-lime-light: #B8D633;
            --warm-white: #F5F5F0;
            --warning: #FF9900;
            --critical: #e53e3e;
        }
        body { 
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; 
            margin: 0; 
            padding: 20px; 
            background: linear-gradient(135deg, var(--jungle-green) 0%, var(--jungle-green-light) 100%);
            min-height: 100vh;
        }
        .container { max-width: 1400px; margin: 0 auto; }
        
        .header { 
            background: white; 
            padding: 30px; 
            border-radius: 16px; 
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            margin-bottom: 20px;
        }
        .header h1 { 
            margin: 0 0 10px 0; 
            color: #2d3748; 
            font-size: 32px;
        }
        .header p { 
            margin: 0; 
            color: #718096; 
            font-size: 16px;
        }
        .badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: bold;
            margin-left: 10px;
        }
        .badge-live { background: #c6f6d5; color: #22543d; }
        
        .stats { 
            display: grid; 
            grid-template-columns: repeat(4, 1fr); 
            gap: 20px; 
            margin-bottom: 20px;
        }
        .stat-card { 
            background: white; 
            padding: 24px; 
            border-radius: 16px; 
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        }
        .stat-card h3 {
            margin: 0 0 8px 0;
            color: #718096;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .stat-card .value {
            font-size: 36px;
            font-weight: bold;
            margin: 0;
        }
        .stat-card .change {
            font-size: 14px;
            margin-top: 8px;
        }
        .stat-healthy { color: var(--neon-lime); }
        .stat-warning { color: var(--warning); }
        .stat-critical { color: var(--critical); }
        .stat-revenue { color: var(--neon-lime-light); }
        
        .client-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
            gap: 20px;
        }
        
        .client-card {
            background: white;
            border-radius: 16px;
            padding: 24px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1);
            border-left: 4px solid;
        }
        .client-card.healthy { border-left-color: var(--neon-lime); }
        .client-card.warning { border-left-color: var(--warning); }
        .client-card.critical { border-left-color: var(--critical); }
        
        .client-header {
            display: flex;
            justify-content: space-between;
            align-items: start;
            margin-bottom: 16px;
        }
        .client-name {
            font-size: 20px;
            font-weight: bold;
            color: #2d3748;
            margin: 0;
        }
        .client-plan {
            font-size: 12px;
            padding: 4px 10px;
            border-radius: 12px;
            background: #edf2f7;
            color: #4a5568;
        }
        
        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 600;
        }
        .status-healthy { background: rgba(159, 191, 0, 0.2); color: var(--jungle-green); }
        .status-warning { background: rgba(255, 153, 0, 0.2); color: #744210; }
        .status-critical { background: rgba(229, 62, 62, 0.2); color: var(--critical); }
        
        .metrics {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            margin: 16px 0;
        }
        .metric {
            text-align: center;
            padding: 12px;
            background: #f7fafc;
            border-radius: 8px;
        }
        .metric-label {
            font-size: 12px;
            color: #718096;
            margin-bottom: 4px;
        }
        .metric-value {
            font-size: 20px;
            font-weight: bold;
            color: #2d3748;
        }
        
        .services {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin: 12px 0;
        }
        .service-tag {
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 12px;
            background: #e2e8f0;
            color: #4a5568;
        }
        .service-tag.running { background: rgba(159, 191, 0, 0.2); color: var(--jungle-green); }
        .service-tag.down { background: rgba(229, 62, 62, 0.2); color: var(--critical); }
        
        .ai-analysis {
            background: linear-gradient(135deg, rgba(159, 191, 0, 0.1) 0%, rgba(11, 58, 44, 0.1) 100%);
            border-radius: 12px;
            padding: 16px;
            margin-top: 16px;
        }
        .ai-analysis h4 {
            margin: 0 0 8px 0;
            color: var(--jungle-green);
            font-size: 13px;
            text-transform: uppercase;
        }
        .ai-analysis p {
            margin: 0;
            color: #4a5568;
            font-size: 14px;
            line-height: 1.5;
        }
        
        .recommendations {
            margin-top: 12px;
        }
        .recommendations li {
            font-size: 13px;
            color: #4a5568;
            margin: 4px 0;
        }
        
        .footer {
            text-align: center;
            padding: 20px;
            color: rgba(245, 245, 240, 0.8);
            font-size: 14px;
        }
        
        .footer p {
            color: rgba(245, 245, 240, 0.8);
        }
        
        .badge-live { 
            background: rgba(159, 191, 0, 0.2); 
            color: var(--neon-lime); 
        }
        
        @media (max-width: 768px) {
            .stats { grid-template-columns: repeat(2, 1fr); }
            .client-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
